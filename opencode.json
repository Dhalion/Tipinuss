{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        }
    },
    "lsp": {
        "php": {
            "command": [
                "phpactor",
                "language-server"
            ],
            "extensions": [
                "php"
            ]
        }
    }
}